library(bigrquery)
library(glue)
library(R6)
# Define the NDTGuide class using R6
NDTGuide <- R6Class("NDTGuide",
public = list(
client = NULL,  # Initialize the client attribute
# Authenticate and create a BigQuery client
login = function() {
bq_auth()  # Authenticate with Google
cat("Authenticated\n")
self$client <- bigrquery::bq_project("measurement-lab")
},
# Return the BigQuery client object
get_client = function() {
self$client
},
# Static method to get full table path
get_table_path = function(table_name) {
# Ensures table_name is either "ndt5" or "ndt7"
namespace <- "measurement-lab.ndt"
tables <- c("ndt5", "ndt7")
stopifnot(table_name %in% tables)
glue("{namespace}.{table_name}")
},
# Execute SQL query and return data as dataframe
exec_sql = function(sql) {
bigrquery::bq_table_download(bigrquery::bq_project_query(self$client, sql))
},
# Generate SQL for daily aggregates based on provided filters
sql_daily_aggregate = function(
table_name, date_start, date_end, aggr_func,
client_asn = NULL, client_cidr = NULL, client_country = NULL,
server_asn = NULL, server_cidr = NULL, server_country = NULL
) {
# Ensure valid aggregation function
stopifnot(aggr_func %in% c("avg", "min", "max"))
stopifnot(!is.null(date_start) && date_start != "")
stopifnot(!is.null(date_end) && date_end != "")
table_path <- self$get_table_path(table_name)
where_str <- ""
# Add conditional WHERE clauses
if (!is.null(client_asn) && client_asn != "") {
where_str <- glue("{where_str} and client.Network.ASNumber={client_asn}")
}
if (!is.null(client_cidr) && client_cidr != "") {
where_str <- glue("{where_str} and client.Network.CIDR='{client_cidr}'")
}
if (!is.null(client_country) && client_country != "") {
where_str <- glue("{where_str} and client.Geo.CountryCode='{toupper(client_country)}'")
}
if (!is.null(server_asn) && server_asn != "") {
where_str <- glue("{where_str} and server.Network.ASNumber={server_asn}")
}
if (!is.null(server_cidr) && server_cidr != "") {
where_str <- glue("{where_str} and server.Network.CIDR='{server_cidr}'")
}
if (!is.null(server_country) && server_country != "") {
where_str <- glue("{where_str} and server.Geo.CountryCode='{toupper(server_country)}'")
}
# Construct the SQL query
glue("
SELECT {aggr_func}(a.MeanThroughputMbps) as {aggr_func}_throughput,
{aggr_func}(a.MinRTT) as {aggr_func}_rtt,
{aggr_func}(a.lossrate) as {aggr_func}_lossrate,
date
FROM `{table_path}`
WHERE a.MeanThroughputMbps > 0
AND a.MinRTT > 0
AND a.lossrate > 0
AND date >= '{date_start}'
AND date <= '{date_end}' {where_str}
GROUP BY date
ORDER BY date;
")
},
# Generate SQL for fetching server information
sql_get_servers = function(table_name, date_start, date_end, client_asn = NULL) {
table_path <- self$get_table_path(table_name)
where_str <- ifelse(!is.null(client_asn) && client_asn != "",
glue(" and client.Network.ASNumber={client_asn}"), "")
glue("
SELECT DISTINCT server.Site, server.Machine,
server.Network.ASNumber, server.Network.ASName,
server.Network.CIDR, server.Geo.CountryCode,
server.Geo.City
FROM `{table_path}`
WHERE date >= '{date_start}' AND date <= '{date_end}' {where_str}
")
},
# Generate SQL for fetching client information
sql_get_clients = function(table_name, date_start, date_end, server_asn = NULL) {
table_path <- self$get_table_path(table_name)
where_str <- ifelse(!is.null(server_asn) && server_asn != "",
glue(" and client.Network.ASNumber={server_asn}"), "")
glue("
SELECT DISTINCT client.Network.ASNumber,
client.Network.ASName,
client.Geo.CountryCode
FROM `{table_path}`
WHERE date >= '{date_start}' AND date <= '{date_end}' {where_str}
")
},
# Static method for schema details
get_schema = function() {
list(
id = "string",
date = "date",
server = list(
Site = "string",
Machine = "string",
Geo = list(
CountryCode = "string",
CountryName = "string",
City = "string",
ContinentCode = "string"
),
Network = list(
CIDR = "string",
ASNumber = "integer",
ASName = "string"
)
),
client = list(
Geo = list(
CountryCode = "string",
CountryName = "string",
City = "string",
ContinentCode = "string"
),
Network = list(
CIDR = "string",
ASNumber = "integer",
ASName = "string"
)
),
a = list(
UUID = "string",
CongestionControl = "string",
TestTime = "TimeStamp",
MeanThroughputMbps = "float",
MinRTT = "float",
LossRate = "float"
)
)
}
)
)
View(NDTGuide)
